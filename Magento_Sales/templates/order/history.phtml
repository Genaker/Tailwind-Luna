declare(strict_types=1);

/** @var \Magento\Sales\Block\Order\History $block */
?>
<?php $_orders = $block->getOrders(); ?>
<?= $block->getChildHtml('info') ?>
<?php if ($_orders && count($_orders)) : ?>
    <div class="orders-history overflow-x-auto rounded-lg border border-neutral-200">
        <table class="table data table-order-items history w-full border-collapse text-sm" id="my-orders-table">
            <caption class="sr-only"><?= $block->escapeHtml(__('Orders')) ?></caption>
            <thead>
                <tr class="border-b border-neutral-200 bg-neutral-50">
                    <th scope="col" class="id px-4 py-3 text-left text-sm font-semibold text-neutral-800"><?= $block->escapeHtml(__('Order #')) ?></th>
                    <th scope="col" class="date px-4 py-3 text-left text-sm font-semibold text-neutral-800"><?= $block->escapeHtml(__('Date')) ?></th>
                    <?= $block->getChildHtml('extra.column.header') ?>
                    <th scope="col" class="total px-4 py-3 text-left text-sm font-semibold text-neutral-800"><?= $block->escapeHtml(__('Order Total')) ?></th>
                    <th scope="col" class="status px-4 py-3 text-left text-sm font-semibold text-neutral-800"><?= $block->escapeHtml(__('Status')) ?></th>
                    <th scope="col" class="px-4 py-3 text-right text-sm font-semibold text-neutral-800"><?= $block->escapeHtml(__('Action')) ?></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($_orders as $_order) : ?>
                    <tr class="border-b border-neutral-200 last:border-b-0">
                        <td data-th="<?= $block->escapeHtml(__('Order #')) ?>" class="id px-4 py-3 align-top text-neutral-800"><?= $block->escapeHtml($_order->getRealOrderId()) ?></td>
                        <td data-th="<?= $block->escapeHtml(__('Date')) ?>" class="date px-4 py-3 align-top text-neutral-700"><?= /* @noEscape */ $block->formatDate($_order->getCreatedAt()) ?></td>
                        <?php $extra = $block->getChildBlock('extra.container'); ?>
                        <?php if ($extra) : ?>
                            <?php $extra->setOrder($_order); ?>
                            <?= $extra->getChildHtml() ?>
                        <?php endif; ?>
                        <td data-th="<?= $block->escapeHtml(__('Order Total')) ?>" class="total px-4 py-3 align-top font-medium text-neutral-900"><?= /* @noEscape */ $_order->formatPrice($_order->getGrandTotal()) ?></td>
                        <td data-th="<?= $block->escapeHtml(__('Status')) ?>" class="status px-4 py-3 align-top text-neutral-700"><?= $block->escapeHtml($_order->getStatusLabel()) ?></td>
                        <td data-th="<?= $block->escapeHtml(__('Action')) ?>" class="px-4 py-3 align-top text-right">
                            <div class="flex flex-wrap items-center justify-end gap-2">
                            <a href="<?= $block->escapeUrl($block->getViewUrl($_order)) ?>" class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold border px-4 py-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:opacity-50 disabled:pointer-events-none view">
                                <span><?= $block->escapeHtml(__('View Order')) ?></span>
                            </a>
                            <?php if ($this->helper(\Magento\Sales\Helper\Reorder::class)->canReorder($_order->getEntityId())) : ?>
                                <a href="#" data-post='<?= /* @noEscape */
                                $this->helper(\Magento\Framework\Data\Helper\PostHelper::class)
                                    ->getPostData($block->getReorderUrl($_order))
                                ?>' class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold border px-4 py-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:opacity-50 disabled:pointer-events-none order">
                                    <span><?= $block->escapeHtml(__('Reorder')) ?></span>
                                </a>
                            <?php endif ?>
                            </div>
                        </td>
                    </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    </div>
    <?php if ($block->getPagerHtml()) : ?>
        <div class="flex flex-wrap items-center justify-between gap-3 py-2 order-products-toolbar bottom"><?= $block->getPagerHtml() ?></div>
    <?php endif ?>
<?php else : ?>
    <div class="mb-4 rounded-md border text-sm border-blue-200 bg-blue-50 text-blue-900 empty"><span><?= $block->escapeHtml($block->getEmptyOrdersMessage()) ?></span></div>
<?php endif ?>
