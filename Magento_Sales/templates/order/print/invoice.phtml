declare(strict_types=1);

/** @var \Magento\Sales\Block\Order\PrintOrder\Invoice $block */
$_order = $block->getOrder();
$_invoice = $block->getInvoice();
if ($_invoice) {
    $_invoices = [$_invoice];
} else {
    $_invoices = $_order->getInvoiceCollection();
}
?>
<?php foreach ($_invoices as $_invoice) : ?>
<div class="order-details-items invoice">
    <div class="order-title mb-4">
        <strong class="text-lg font-semibold text-neutral-900"><?= $block->escapeHtml(__('Invoice #')) ?><?= $block->escapeHtml($_invoice->getIncrementId()) ?></strong>
    </div>
    <div class="overflow-x-auto rounded-lg border border-neutral-200 table-order-items invoice">
        <table class="table data table-order-items invoice w-full border-collapse text-sm" id="my-invoice-table-<?= (int) $_invoice->getId() ?>">
            <caption class="sr-only"><?= $block->escapeHtml(__('Items Invoiced')) ?></caption>
            <thead>
            <tr class="border-b border-neutral-200 bg-neutral-50">
                <th class="name px-4 py-3 text-left text-sm font-semibold text-neutral-800" scope="col"><?= $block->escapeHtml(__('Product Name')) ?></th>
                <th class="sku px-4 py-3 text-left text-sm font-semibold text-neutral-800" scope="col"><?= $block->escapeHtml(__('SKU')) ?></th>
                <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-800" scope="col"><?= $block->escapeHtml(__('Price')) ?></th>
                <th class="px-4 py-3 text-center text-sm font-semibold text-neutral-800" scope="col"><?= $block->escapeHtml(__('Qty Invoiced')) ?></th>
                <th class="subtotal px-4 py-3 text-left text-sm font-semibold text-neutral-800" scope="col"><?= $block->escapeHtml(__('Subtotal')) ?></th>
            </tr>
            </thead>
            <?php $_items = $_invoice->getItemsCollection(); ?>
            <?php foreach ($_items as $_item) : ?>
                <?php if (!$_item->getOrderItem()->getParentItem()) : ?>
                    <tbody>
                        <?= $block->getItemHtml($_item) ?>
                    </tbody>
                <?php endif; ?>
            <?php endforeach; ?>
            <tfoot>
                <?= $block->getInvoiceTotalsHtml($_invoice) ?>
            </tfoot>
        </table>
    </div>
    <div class="mb-8 mt-8">
        <div class="text-lg font-semibold text-neutral-900 mb-3 pb-2 border-b border-neutral-200">
            <strong><?= $block->escapeHtml(__('Order Information')) ?></strong>
        </div>
        <div class="text-sm text-neutral-700 [&_address]:not-italic">
        <?php if (!$_order->getIsVirtual()) : ?>
            <div class="mb-6 rounded-lg border border-neutral-200 bg-white box-order-shipping-address">
                <div class="px-4 py-3 text-base font-semibold border-b border-neutral-200 bg-neutral-50">
                    <strong><?= $block->escapeHtml(__('Shipping Address')) ?></strong>
                </div>
                <div class="p-4">
                    <?php $_shipping = $_invoice->getShippingAddress() ?>
                    <address><?= /* @noEscape */ $block->formatAddress($_shipping, 'html') ?></address>
                </div>
            </div>

            <div class="mb-6 rounded-lg border border-neutral-200 bg-white box-order-shipping-method">
                <div class="px-4 py-3 text-base font-semibold border-b border-neutral-200 bg-neutral-50">
                    <strong><?= $block->escapeHtml(__('Shipping Method')) ?></strong>
                </div>
                <div class="p-4">
                    <?php if ($_order->getShippingDescription()) : ?>
                        <?= $block->escapeHtml($_order->getShippingDescription()) ?>
                    <?php else : ?>
                        <?= $block->escapeHtml(__('No shipping information available')) ?>
                    <?php endif; ?>
                </div>
            </div>
        <?php endif; ?>
            <div class="mb-6 rounded-lg border border-neutral-200 bg-white box-order-billing-address">
                <div class="px-4 py-3 text-base font-semibold border-b border-neutral-200 bg-neutral-50">
                    <strong><?= $block->escapeHtml(__('Billing Address')) ?></strong>
                </div>
                <div class="p-4">
                    <address><?= /* @noEscape */ $block->formatAddress($_order->getBillingAddress(), 'html') ?></address>
                </div>
            </div>

            <div class="mb-6 rounded-lg border border-neutral-200 bg-white box-order-billing-method">
                <div class="px-4 py-3 text-base font-semibold border-b border-neutral-200 bg-neutral-50">
                    <strong><?= $block->escapeHtml(__('Payment Method')) ?></strong>
                </div>
                <div class="p-4">
                    <?= $block->getPaymentInfoHtml() ?>
                </div>
            </div>
        </div>
    </div>
</div>
<?php endforeach; ?>
