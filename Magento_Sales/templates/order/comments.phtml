declare(strict_types=1);

/**
 * @var \Magento\Sales\Block\Order\Comments $block
 */
?>
<?php if ($block->hasComments()) : ?>
    <div class="order additional comments mb-6 rounded-lg border border-neutral-200 bg-white p-4 text-sm">
        <h3 class="text-base font-semibold text-neutral-900 mb-3"><?= $block->escapeHtml($block->getTitle()) ?></h3>
        <dl class="order comments space-y-3">
            <?php foreach ($block->getComments() as $_commentItem) : ?>
                <div class="border-l-2 border-neutral-200 pl-3">
                    <dt class="comment date text-xs font-medium text-neutral-500 tabular-nums">
                        <?= /* @noEscape */
                        $block->formatDate($_commentItem->getCreatedAt(), \IntlDateFormatter::MEDIUM, true) ?>
                    </dt>
                    <dd class="comment text mt-1 text-neutral-800"><?= $block->escapeHtml($_commentItem->getComment()) ?></dd>
                </div>
            <?php endforeach; ?>
        </dl>
    </div>
<?php endif; ?>
