/**
 * @var \Magento\Sales\Block\Order\Item\Renderer\DefaultRenderer $block
 * @var \Magento\Framework\Locale\LocaleFormatter $localeFormatter
 */
$_item = $block->getItem();
?>
<tr id="order-item-row-<?= (int) $_item->getId() ?>" class="border-b border-neutral-200 last:border-b-0">
    <td class="name px-4 py-3 align-top text-neutral-800" data-th="<?= $block->escapeHtml(__('Product Name')) ?>">
        <strong class="product name text-base font-semibold leading-snug text-neutral-900"><?= $block->escapeHtml($_item->getName()) ?></strong>
        <?php if ($_options = $block->getItemOptions()): ?>
            <dl class="item-options mt-2 space-y-1 text-xs text-neutral-600">
            <?php foreach ($_options as $_option): ?>
                <dt class="font-medium text-neutral-800"><?= $block->escapeHtml($_option['label']) ?></dt>
                <?php if (!$block->getPrintStatus()): ?>
                    <?php $_formatedOptionValue = $block->getFormatedOptionValue($_option) ?>
                    <dd<?= (isset($_formatedOptionValue['full_view']) ? ' class="inline-block w-full"' : '') ?>>
                        <?= $block->escapeHtml($_formatedOptionValue['value'], ['a']) ?>
                        <?php if (isset($_formatedOptionValue['full_view'])): ?>
                            <div class="inline-block content">
                                <dl class="flex flex-col border border-neutral-200 rounded-lg bg-white overflow-hidden options">
                                    <dt><?= $block->escapeHtml($_option['label']) ?></dt>
                                    <dd><?= $block->escapeHtml($_formatedOptionValue['full_view']) ?></dd>
                                </dl>
                            </div>
                        <?php endif; ?>
                    </dd>
                <?php else: ?>
                    <?php $optionValue = isset($_option['print_value']) ? $_option['print_value'] : $_option['value'] ?>
                    <dd><?= $block->escapeHtml($optionValue) ?></dd>
                <?php endif; ?>
            <?php endforeach; ?>
            </dl>
        <?php endif; ?>
        <?php $addtInfoBlock = $block->getProductAdditionalInformationBlock(); ?>
        <?php if ($addtInfoBlock): ?>
            <?= $addtInfoBlock->setItem($_item)->toHtml() ?>
        <?php endif; ?>
        <?= $block->escapeHtml($_item->getDescription()) ?>
    </td>
    <td class="sku px-4 py-3 align-top text-sm text-neutral-700" data-th="<?= $block->escapeHtml(__('SKU')) ?>">
        <?= /* @noEscape */ $block->prepareSku($block->getSku()) ?>
    </td>
    <td class="px-4 py-3 align-top text-sm font-medium text-neutral-900" data-th="<?= $block->escapeHtml(__('Price')) ?>">
        <?= $block->getItemPriceHtml() ?>
    </td>
    <td class="px-4 py-3 align-top text-center text-sm text-neutral-800" data-th="<?= $block->escapeHtml(__('Qty')) ?>">
        <ul class="items-qty space-y-2 text-left">
        <?php if ($block->getItem()->getQtyOrdered() > 0): ?>
            <li>
                <span class="block text-xs font-medium text-neutral-600"><?= $block->escapeHtml(__('Ordered')) ?></span>
                <span class="content tabular-nums">
                    <?= $block->escapeHtml($localeFormatter->formatNumber((float) $block->getItem()->getQtyOrdered()))?>
                </span>
            </li>
        <?php endif; ?>
        <?php if ($block->getItem()->getQtyShipped() > 0): ?>
            <li>
                <span class="block text-xs font-medium text-neutral-600"><?= $block->escapeHtml(__('Shipped')) ?></span>
                <span class="content tabular-nums">
                    <?= $block->escapeHtml($localeFormatter->formatNumber((float) $block->getItem()->getQtyShipped()))?>
                </span>
            </li>
        <?php endif; ?>
        <?php if ($block->getItem()->getQtyCanceled() > 0): ?>
            <li>
                <span class="block text-xs font-medium text-neutral-600"><?= $block->escapeHtml(__('Canceled')) ?></span>
                <span class="content tabular-nums">
                    <?= $block->escapeHtml(
                        $localeFormatter->formatNumber((float) $block->getItem()->getQtyCanceled())
                    )?>
                </span>
            </li>
        <?php endif; ?>
        <?php if ($block->getItem()->getQtyRefunded() > 0): ?>
            <li>
                <span class="block text-xs font-medium text-neutral-600"><?= $block->escapeHtml(__('Refunded')) ?></span>
                <span class="content tabular-nums">
                    <?= $block->escapeHtml(
                        $localeFormatter->formatNumber((float) $block->getItem()->getQtyRefunded())
                    )?>
                </span>
            </li>
        <?php endif; ?>
        </ul>
    </td>
    <td class="subtotal px-4 py-3 align-top text-sm font-medium text-neutral-900" data-th="<?= $block->escapeHtml(__('Subtotal')) ?>">
        <?= $block->getItemRowTotalHtml() ?>
    </td>
</tr>
