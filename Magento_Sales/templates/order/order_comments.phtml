declare(strict_types=1);

/** @var \Magento\Sales\Block\Order\View $block */

$_history = $block->getOrder()->getVisibleStatusHistory();
?>
<?php if (!empty($_history)) : ?>
    <div class="mb-8">
        <div class="text-lg font-semibold text-neutral-900 mb-3 pb-2 border-b border-neutral-200">
            <strong><?= $block->escapeHtml(__('About Your Order')) ?></strong>
        </div>
        <div class="text-sm text-neutral-700">
            <dl class="order-comments space-y-3">
                <?php foreach ($_history as $_historyItem) : ?>
                    <div class="border-l-2 border-neutral-200 pl-3">
                        <dt class="comment-date text-xs font-medium text-neutral-500 tabular-nums">
                            <?= /* @noEscape */
                            $block->formatDate($_historyItem->getCreatedAt(), \IntlDateFormatter::MEDIUM, true) ?>
                        </dt>
                        <dd class="comment-content mt-1"><?= $block->escapeHtml($_historyItem->getComment(), ['b', 'br', 'strong', 'i', 'u', 'a']) ?></dd>
                    </div>
                <?php endforeach; ?>
            </dl>
        </div>
    </div>
<?php endif; ?>
