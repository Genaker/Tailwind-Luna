use Magento\Downloadable\Model\Link\Purchased\Item;

/**
 * @var $block \Magento\Downloadable\Block\Customer\Products\ListProducts
 * @var \Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer
 */
?>
<?php $_items = $block->getItems(); ?>
<?php if (count($_items)): ?>
    <div class="downloadable-products overflow-x-auto rounded-lg border border-neutral-200">
        <table id="my-downloadable-products-table" class="table data table-downloadable-products w-full border-collapse text-sm">
            <caption class="sr-only"><?= $block->escapeHtml(__('Downloadable Products')) ?></caption>
            <thead>
                <tr class="border-b border-neutral-200 bg-neutral-50">
                    <th scope="col" class="id px-4 py-3 text-left text-sm font-semibold text-neutral-800"><?= $block->escapeHtml(__('Order #')) ?></th>
                    <th scope="col" class="date px-4 py-3 text-left text-sm font-semibold text-neutral-800"><?= $block->escapeHtml(__('Date')) ?></th>
                    <th scope="col" class="px-4 py-3 text-left text-sm font-semibold text-neutral-800"><?= $block->escapeHtml(__('Title')) ?></th>
                    <th scope="col" class="status px-4 py-3 text-left text-sm font-semibold text-neutral-800"><?= $block->escapeHtml(__('Status')) ?></th>
                    <th scope="col" class="remaining px-4 py-3 text-left text-sm font-semibold text-neutral-800"><?= $block->escapeHtml(__('Remaining Downloads')) ?></th>
                </tr>
            </thead>
            <tbody>
            <?php foreach ($_items as $_item): ?>
                <tr class="border-b border-neutral-200 last:border-b-0">
                    <td data-th="<?= $block->escapeHtmlAttr(__('Order #')) ?>" class="id px-4 py-3 align-top text-neutral-800">
                        <a href="<?= $block->escapeUrl($block->getOrderViewUrl($_item->getPurchased()->getOrderId())) ?>"
                           title="<?= $block->escapeHtmlAttr(__('View Order')) ?>">
                            <?= $block->escapeHtml($_item->getPurchased()->getOrderIncrementId()) ?>
                        </a>
                    </td>
                    <td data-th="<?= $block->escapeHtmlAttr(__('Date')) ?>" class="date px-4 py-3 align-top text-neutral-700">
                        <?= $block->escapeHtml($block->formatDate($_item->getPurchased()->getCreatedAt())) ?>
                    </td>
                    <td data-th="<?= $block->escapeHtmlAttr(__('Title')) ?>" class="px-4 py-3 align-top text-neutral-900">
                        <strong class="product-name block font-medium text-neutral-900">
                            <?= $block->escapeHtml($_item->getPurchased()->getProductName()) ?>
                        </strong>
                        <?php if ($_item->getStatus() == Item::LINK_STATUS_AVAILABLE): ?>
                            <a href="<?= $block->escapeUrl($block->getDownloadUrl($_item)) ?>"
                               id="download_<?= /* @noEscape */ $_item->getPurchased()->getProductId() ?>"
                               title="<?= $block->escapeHtmlAttr(__('Start Download')) ?>"
                               class="download mt-2 inline-flex items-center justify-center gap-2 rounded-md border border-blue-600 bg-blue-600 px-3 py-1.5 text-sm font-semibold text-white transition-colors hover:bg-blue-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600">
                                <?= $block->escapeHtml($_item->getLinkTitle()) ?>
                            </a>
                            <?php if ($block->getIsOpenInNewWindow()): ?>
                                <?= /* @noEscape */ $secureRenderer->renderEventListenerAsTag(
                                    'onclick',
                                    "this.target='_blank'",
                                    'a#download_' . $_item->getPurchased()->getProductId()
                                ) ?>
                            <?php endif; ?>
                        <?php endif; ?>
                    </td>
                    <td data-th="<?= $block->escapeHtmlAttr(__('Status')) ?>" class="status px-4 py-3 align-top text-neutral-700">
                        <?= $block->escapeHtml(__(ucfirst($_item->getStatus()))) ?>
                    </td>
                    <td data-th="<?= $block->escapeHtmlAttr(__('Remaining Downloads')) ?>" class="remaining px-4 py-3 align-top tabular-nums text-neutral-800">
                        <?= $block->escapeHtml($block->getRemainingDownloads($_item)) ?>
                    </td>
                </tr>
            <?php endforeach; ?>
            </tbody>
        </table>
    </div>
    <?php if ($block->getChildHtml('pager')): ?>
        <div class="downloadable-products-toolbar bottom flex flex-wrap items-center justify-between gap-3 py-2">
            <?= $block->getChildHtml('pager') ?>
        </div>
    <?php endif; ?>
<?php else: ?>
    <div class="empty mb-4 rounded-lg border border-neutral-200 bg-neutral-50 p-4 text-sm text-neutral-700">
        <span><?= $block->escapeHtml(__('You have not purchased any downloadable products yet.')) ?></span>
    </div>
<?php endif; ?>

<div class="clear-both py-4">
    <a href="<?= $block->escapeUrl($block->getBackUrl()) ?>"
       class="back inline-flex items-center justify-center gap-2 rounded-md border border-neutral-300 bg-white px-4 py-2 text-sm font-semibold text-neutral-900 transition-colors hover:bg-neutral-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600">
        <span><?= $block->escapeHtml(__('Back')) ?></span>
    </a>
</div>
