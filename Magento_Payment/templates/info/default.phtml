/**
 * @var \Magento\Payment\Block\Info $block
 * @see \Magento\Payment\Block\Info
 */
$specificInfo = $block->getSpecificInformation();
$title = $block->escapeHtml($block->getMethod()->getTitle());
?>
<dl class="payment-method space-y-2 text-sm text-neutral-800">
    <dt class="text-base font-semibold text-neutral-900"><?= /* @noEscape */ $title ?></dt>
<?php if ($specificInfo) : ?>
    <dd class="content">
        <div class="overflow-x-auto rounded-lg border border-neutral-200">
        <table class="table data w-full border-collapse">
            <caption class="sr-only"><?= /* @noEscape */ $title ?></caption>
            <?php foreach ($specificInfo as $label => $value) : ?>
                <tr class="border-b border-neutral-200 last:border-b-0">
                    <th class="px-4 py-3 text-left text-sm font-medium text-neutral-800" scope="row"><?= $block->escapeHtml($label) ?></th>
                    <td class="px-4 py-3 text-sm text-neutral-700">
                        <?= /* @noEscape */ nl2br($block->escapeHtml(implode("\n", $block->getValueAsArray($value, true)))) ?>
                    </td>
                </tr>
            <?php endforeach; ?>
        </table>
        </div>
    </dd>
<?php endif; ?>
</dl>
<?= $block->getChildHtml() ?>
