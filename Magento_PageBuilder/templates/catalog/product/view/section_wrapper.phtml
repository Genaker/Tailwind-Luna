/**
 * Wrapper for product sections to include title
 *
 * @var Template $block
 * @var Escaper $escaper
 */

use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

$childHtml = $block->getChildHtml();
$sectionId = $block->getSectionId();
$sectionIdAttribute = $sectionId ? ' id="' . $escaper->escapeHtmlAttr($sectionId) . '"' : '';
?>
<?php if (trim($childHtml) !== ""): ?>
    <div class="product-full-width-section mb-8 space-y-3 last:mb-0"<?= /* @noEscape */ $sectionIdAttribute ?>>
        <h2 class="product-section-title text-lg font-semibold text-neutral-900 border-b border-neutral-200 pb-2"><?= $escaper->escapeHtml($block->getTitle()); ?></h2>
        <?= $block->getChildHtml(); ?>
    </div>
<?php endif; ?>
