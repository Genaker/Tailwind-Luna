<?php
/**
 * Product detail tabs — proper tablist/tab/tabpanel ARIA, no mage.tabs widget.
 *
 * @var \Magento\Catalog\Block\Product\View\Details $block
 */
$layout = $block->getLayout();
$detailedInfoGroup = $block->getGroupSortedChildNames('detailed_info', 'getChildHtml');
$tabs = [];
if ($detailedInfoGroup) {
    foreach ($detailedInfoGroup as $name) {
        $html = $layout->renderElement($name);
        if (!$html || !trim($html)) {
            continue;
        }
        $alias = $layout->getElementAlias($name);
        $tabs[] = [
            'alias' => $alias,
            'label' => $block->getChildData($alias, 'title'),
            'html'  => $html,
        ];
    }
}
?>
<?php if ($tabs !== []): ?>
<div class="product info detailed mt-8 w-full max-w-full sm:mt-10">

    <div class="product-detail-tabs flex w-full border-b border-neutral-200"
         id="product-detail-tabs"
         role="tablist">
        <?php foreach ($tabs as $i => $tab): ?>
            <?php
            $alias   = $tab['alias'];
            $isFirst = $i === 0;
            $btnBase = '-mb-px flex-1 cursor-pointer border-b-2 px-3 py-3 text-center text-sm font-semibold transition-colors sm:px-4';
            $btnActive   = 'border-primary text-primary';
            $btnInactive = 'border-transparent text-neutral-600 hover:border-neutral-200 hover:text-neutral-900';
            ?>
            <button role="tab"
                    id="tab-label-<?= $block->escapeHtmlAttr($alias) ?>"
                    aria-controls="panel-<?= $block->escapeHtmlAttr($alias) ?>"
                    aria-selected="<?= $isFirst ? 'true' : 'false' ?>"
                    tabindex="<?= $isFirst ? '0' : '-1' ?>"
                    class="<?= $block->escapeHtmlAttr($btnBase . ' ' . ($isFirst ? $btnActive : $btnInactive)) ?>">
                <span class="inline-flex min-w-0 flex-wrap items-center justify-center gap-1.5 text-inherit [&_.counter]:inline-flex [&_.counter]:shrink-0 [&_.counter]:items-center [&_.counter]:justify-center [&_.counter]:rounded-full [&_.counter]:bg-primary [&_.counter]:px-1.5 [&_.counter]:py-0.5 [&_.counter]:text-[11px] [&_.counter]:font-bold [&_.counter]:tabular-nums [&_.counter]:leading-none [&_.counter]:text-white [&_.counter]:shadow-sm [&_.counter]:ring-1 [&_.counter]:ring-white/25">
                    <?= /* @noEscape */ $tab['label'] ?>
                </span>
            </button>
        <?php endforeach; ?>
    </div>

    <?php foreach ($tabs as $i => $tab): ?>
        <?php $alias = $tab['alias']; $isFirst = $i === 0; ?>
        <div id="panel-<?= $block->escapeHtmlAttr($alias) ?>"
             role="tabpanel"
             aria-labelledby="tab-label-<?= $block->escapeHtmlAttr($alias) ?>"
             class="w-full min-w-0 border-t border-neutral-200 pt-4 sm:pt-6"
             <?= $isFirst ? '' : 'hidden' ?>>
            <?= /* @noEscape */ $tab['html'] ?>
        </div>
    <?php endforeach; ?>

    <script>
    (function () {
        var tablist = document.getElementById('product-detail-tabs');
        if (!tablist) return;
        var btns = tablist.querySelectorAll('[role="tab"]');
        btns.forEach(function (btn) {
            btn.addEventListener('click', function () {
                btns.forEach(function (b) {
                    b.setAttribute('aria-selected', 'false');
                    b.setAttribute('tabindex', '-1');
                    b.classList.remove('border-primary', 'text-primary');
                    b.classList.add('border-transparent', 'text-neutral-600');
                    var panel = document.getElementById(b.getAttribute('aria-controls'));
                    if (panel) panel.hidden = true;
                });
                btn.setAttribute('aria-selected', 'true');
                btn.setAttribute('tabindex', '0');
                btn.classList.add('border-primary', 'text-primary');
                btn.classList.remove('border-transparent', 'text-neutral-600');
                var active = document.getElementById(btn.getAttribute('aria-controls'));
                if (active) active.hidden = false;
            });
        });
    })();
    </script>

</div>
<?php endif; ?>
