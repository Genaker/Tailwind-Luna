/**
 * @var \Magento\Review\Block\Customer\View $block
 * @var \Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer
 */

$product = $block->getProductData();
?>
<?php if ($product->getId()): ?>
<div class="customer-review view space-y-6">
    <div class="product-details flex flex-col gap-6 rounded-lg border border-neutral-200 bg-white p-4 shadow-sm sm:flex-row sm:p-6">
        <div class="product-media shrink-0">
            <a class="product-photo block overflow-hidden rounded-lg border border-neutral-200 bg-neutral-50"
               href="<?= $block->escapeUrl($product->getProductUrl()) ?>">
                <?php /* customer_account_product_review_page */ ?>
                <?= $block->getImage($block->getProductData(), 'customer_account_product_review_page')->toHtml() ?>
            </a>
        </div>
        <div class="product-info min-w-0 flex-1">
            <h2 class="product-name text-xl font-semibold text-neutral-900"><?= $block->escapeHtml($product->getName()) ?></h2>
            <?php if ($block->getRating() && $block->getRating()->getSize()): ?>
                <div class="rating-average-label mt-2 text-sm font-medium text-neutral-700"><?= $block->escapeHtml(__('Average Customer Rating:')) ?></div>
                <div class="mt-1"><?= $block->getReviewsSummaryHtml($product) ?></div>
            <?php endif; ?>
        </div>
    </div>

    <div class="review-details rounded-lg border border-neutral-200 bg-white p-4 shadow-sm sm:p-6">
        <?php if ($block->getRating() && $block->getRating()->getSize()): ?>
            <div class="border-b border-neutral-200 pb-3 text-base font-semibold text-neutral-900">
                <strong><?= $block->escapeHtml(__('Your Review')) ?></strong>
            </div>
            <div class="customer-review-rating mt-3 space-y-2">
                <?php foreach ($block->getRating() as $_rating): ?>
                    <?php if ($_rating->getPercent()): ?>
                        <?php $rating = ceil($_rating->getPercent()) ?>
                        <?php $ratingId = $_rating->getRatingId() ?>
                        <div class="rating-summary flex flex-wrap items-center gap-3">
                            <span class="rating-label text-sm font-medium text-neutral-700">
                                <span><?= $block->escapeHtml($_rating->getRatingCode()) ?></span>
                            </span>
                            <div class="rating-result <?= $block->escapeHtml($_rating->getRatingCode()) ?>"
                                 id="rating-div-<?= $block->escapeHtml($ratingId) ?>"
                                 title="<?= /* @noEscape */ $rating ?>%">
                                <span>
                                    <span><?= /* @noEscape */ $rating ?>%</span>
                                </span>
                            </div>
                            <?= /* @noEscape */
                            $secureRenderer->renderStyleAsTag(
                                "width:" . /* @noEscape */ $rating . "%",
                                'div#rating-div-'.$_rating->getRatingId().
                                '>span:first-child'
                            ) ?>
                        </div>
                    <?php endif; ?>
                <?php endforeach; ?>
            </div>
        <?php endif; ?>

        <div class="review-title mt-4 text-base font-semibold text-neutral-900"><?= $block->escapeHtml($block->getReviewData()->getTitle()) ?></div>
        <div class="review-content mt-2 text-neutral-800">
            <?= /* @noEscape */ nl2br($block->escapeHtml($block->getReviewData()->getDetail())) ?>
        </div>
        <div class="review-date mt-3 text-xs text-neutral-600">
            <?= $block->escapeHtml(__('Submitted on %1', '<time class="date">' .
                $block->dateFormat($block->getReviewData()->getCreatedAt()) . '</time>'), ['time']) ?>
        </div>
    </div>
</div>
<div class="clear-both border-t border-neutral-200 pt-6">
    <a class="back inline-flex items-center justify-center gap-2 rounded-md border border-neutral-300 bg-white px-4 py-2 text-sm font-semibold text-neutral-900 transition-colors hover:bg-neutral-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600"
       href="<?= $block->escapeUrl($block->getBackUrl()) ?>">
        <span><?= $block->escapeHtml(__('Back to My Reviews')) ?></span>
    </a>
</div>
<?php endif; ?>
