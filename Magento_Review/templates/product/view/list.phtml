use Magento\Framework\Escaper;
use Magento\Framework\View\Helper\SecureHtmlRenderer;
use Magento\Review\Block\Product\View\ListView;

/**
 * @var ListView $block
 * @var SecureHtmlRenderer $secureRenderer
 * @var Escaper $escaper
 */

$_items = $block->getReviewsCollection()->getItems();
$format = $block->getDateFormat() ?: \IntlDateFormatter::SHORT;
?>
<?php if (count($_items)): ?>
    <div class="mb-6 review-list" id="customer-reviews">
        <?php if (!$block->getHideTitle()): ?>
            <div class="text-lg font-semibold text-neutral-900 mb-3 pb-2 border-b border-neutral-200">
                <strong><?= $escaper->escapeHtml(__('Customer Reviews')) ?></strong>
            </div>
        <?php endif ?>
        <div class="text-sm text-neutral-700">
            <div class="flex flex-wrap items-center justify-between gap-3 py-2 review-toolbar">
                <?= $block->getChildHtml('toolbar') ?>
            </div>
            <ol class="review-items m-0 list-none space-y-6 p-0">
                <?php foreach ($_items as $_review): ?>
                    <li class="review-item border-b border-neutral-200 pb-6 last:border-b-0 last:pb-0" itemscope itemprop="review" itemtype="http://schema.org/Review">
                        <div class="review-title text-base font-semibold text-neutral-900" itemprop="name">
                            <?= $escaper->escapeHtml($_review->getTitle()) ?>
                        </div>
                        <?php if (count($_review->getRatingVotes())): ?>
                            <div class="review-ratings mt-2 space-y-2">
                                <?php foreach ($_review->getRatingVotes() as $_vote): ?>
                                    <div class="rating-summary flex flex-wrap items-center gap-3"
                                         itemprop="reviewRating" itemscope itemtype="http://schema.org/Rating">
                                        <span class="rating-label text-sm font-medium text-neutral-700">
                                            <span><?= $escaper->escapeHtml($_vote->getRatingCode()) ?></span>
                                        </span>
                                        <div class="rating-result"
                                             id="review_<?= /* @noEscape */ $_review->getReviewId()
                                                . '_vote_'
                                                . $_vote->getVoteId() ?>"
                                             title="<?= $escaper->escapeHtmlAttr($_vote->getPercent()) ?>%">
                                            <meta itemprop="worstRating" content="1"/>
                                            <meta itemprop="bestRating" content="100"/>
                                            <span style="width: <?= $escaper->escapeHtml($_vote->getPercent()) ?>%;">
                                                <span itemprop="ratingValue">
                                                    <?= $escaper->escapeHtml($_vote->getPercent()) ?>%
                                                </span>
                                            </span>
                                        </div>
                                    </div>
                                <?php endforeach; ?>
                            </div>
                        <?php endif; ?>
                        <div class="review-content-container mt-3 space-y-2">
                            <div class="review-content text-neutral-800" itemprop="description">
                                <?= /* @noEscape */ nl2br($escaper->escapeHtml($_review->getDetail())) ?>
                            </div>
                            <div class="review-details text-xs text-neutral-600">
                                <p class="review-author mb-1">
                                    <span class="review-details-label">
                                        <?= $escaper->escapeHtml(__('Review by')) ?>
                                    </span>
                                    <strong class="review-details-value" itemprop="author">
                                        <?= $escaper->escapeHtml($_review->getNickname()) ?>
                                    </strong>
                                </p>
                                <p class="review-date">
                                    <span class="review-details-label">
                                        <?= $escaper->escapeHtml(__('Posted on')) ?>
                                    </span>
                                    <time class="review-details-value" itemprop="datePublished"
                                          datetime="<?= $escaper->escapeHtmlAttr($block->formatDate(
                                              $_review->getCreatedAt(),
                                              $format
                                          )) ?>">
                                        <?= $escaper->escapeHtml(
                                            $block->formatDate(
                                                $_review->getCreatedAt(),
                                                $format
                                            )
                                        ) ?>
                                    </time>
                                </p>
                            </div>
                        </div>
                    </li>
                <?php endforeach; ?>
            </ol>
            <div class="flex flex-wrap items-center justify-between gap-3 py-2 review-toolbar">
                <?= $block->getChildHtml('toolbar') ?>
            </div>
        </div>
    </div>
<?php endif; ?>
