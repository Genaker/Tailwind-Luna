declare(strict_types=1);

/**
 * @var \Magento\Review\Block\View $block
 * @var \Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer
 * @var \Magento\Framework\Escaper $escaper
 */
?>
<?php if ($block->getProductData()->getId()): ?>
<div class="product-review max-w-4xl space-y-6">
    <div class="w-full">
        <h1 class="text-2xl font-semibold text-neutral-900"><?= $escaper->escapeHtml(__('Review Details')) ?></h1>
    </div>
    <div class="product-img-box space-y-2">
        <a href="<?= $escaper->escapeUrl($block->getProductData()->getProductUrl()) ?>">
            <?= $block->getImage($block->getProductData(), 'product_base_image', [
                'class' => 'product-image max-w-xs rounded-lg border border-neutral-200',
            ])->toHtml() ?>
        </a>
        <?php if ($block->getRating() && $block->getRating()->getSize()): ?>
            <p class="text-sm text-neutral-700"><?= $escaper->escapeHtml(__('Average Customer Rating')) ?>:</p>
            <?= $block->getReviewsSummaryHtml($block->getProductData()) ?>
        <?php endif; ?>
    </div>
    <div class="text-sm space-y-4">
        <h2 class="product-name text-lg font-semibold text-neutral-900"><?= $escaper->escapeHtml($block->getProductData()->getName()) ?></h2>
        <?php if ($block->getRating() && $block->getRating()->getSize()): ?>
            <h3 class="text-base font-semibold text-neutral-800"><?= $escaper->escapeHtml(__('Product Rating:')) ?></h3>
            <div class="overflow-x-auto rounded-lg border border-neutral-200">
                <table class="data-table review-summary-table w-full border-collapse text-sm">
                    <caption class="sr-only"><?= $escaper->escapeHtml(__('Product Rating')) ?></caption>
                    <tbody>
                    <?php foreach ($block->getRating() as $_rating): ?>
                        <?php if ($_rating->getPercent()): ?>
                            <?php $rating = (int) ceil((float) $_rating->getPercent()) ?>
                            <tr class="border-b border-neutral-200 last:border-b-0">
                                <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-800 align-top w-1/3" scope="row">
                                    <?= $escaper->escapeHtml(__($_rating->getRatingCode())) ?>
                                </th>
                                <td class="value px-4 py-3 align-top">
                                    <?php $ratingId = $_rating->getRatingId() ?>
                                    <div class="flex flex-col border border-neutral-200 rounded-lg bg-white overflow-hidden rating-summary"
                                         id="rating-div-<?= $escaper->escapeHtmlAttr((string) $ratingId) ?>">
                                        <div class="rating-result h-2 bg-neutral-100"
                                             title="<?= $escaper->escapeHtmlAttr($rating . '%') ?>">
                                            <span class="block h-full bg-amber-400" style="width: <?= /* @noEscape */ $rating ?>%;">
                                                <span class="sr-only"><?= /* @noEscape */ $rating ?>%</span>
                                            </span>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        <?php endif; ?>
                    <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
        <?php endif; ?>
        <p class="date text-sm text-neutral-600">
            <?= $escaper->escapeHtml(
                __('Product Review (submitted on %1):', $block->dateFormat($block->getReviewData()->getCreatedAt()))
            ) ?>
        </p>
        <div class="text-sm text-neutral-800 leading-relaxed">
            <p><?= /* @noEscape */ nl2br($escaper->escapeHtml($block->getReviewData()->getDetail())) ?></p>
        </div>
    </div>
    <div class="flex flex-wrap gap-2 pt-2">
        <a class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold border px-4 py-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:opacity-50 disabled:pointer-events-none back border-neutral-300 text-neutral-800 hover:bg-neutral-50" href="<?= $escaper->escapeUrl($block->getBackUrl()) ?>">
            <span><?= $escaper->escapeHtml(__('Back to Product Reviews')) ?></span>
        </a>
    </div>
</div>
<?php endif; ?>
