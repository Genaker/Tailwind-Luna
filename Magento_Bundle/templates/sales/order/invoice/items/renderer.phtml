?>
<?php /** @var $block \Magento\Bundle\Block\Sales\Order\Items\Renderer */ ?>
<?php $parentItem = $block->getItem() ?>
<?php $_order = $block->getItem()->getOrderItem()->getOrder() ?>

<?php $items = $block->getChildren($parentItem) ?>
<?php $_index = 0 ?>

<?php $_prevOptionId = '' ?>
<?php foreach ($items as $_item): ?>

    <?php if ($block->getItemOptions() || $parentItem->getDescription() || $this->helper(Magento\GiftMessage\Helper\Message::class)->isMessagesAllowed('order_item', $parentItem) && $parentItem->getGiftMessageId()): ?>
        <?php $_showlastRow = true ?>
    <?php else: ?>
        <?php $_showlastRow = false ?>
    <?php endif; ?>

    <?php if ($_item->getOrderItem()->getParentItem()): ?>
        <?php $attributes = $block->getSelectionAttributes($_item) ?>
        <?php if ($_prevOptionId != $attributes['option_id']): ?>
            <tr class="options-label">
                <td class="border-b border-neutral-200 bg-neutral-50 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-neutral-700" colspan="5">
                    <span class="option"><?= $block->escapeHtml($attributes['option_label']) ?></span>
                </td>
            </tr>
            <?php $_prevOptionId = $attributes['option_id'] ?>
        <?php endif; ?>
    <?php endif; ?>
    <tr id="order-item-row-<?= $block->escapeHtmlAttr($_item->getId()) ?>"
        class="border-b border-neutral-200 last:border-b-0 <?php if ($_item->getOrderItem()->getParentItem()): ?>item-options-container
        <?php else: ?>item-parent
        <?php endif; ?>"
        <?php if ($_item->getOrderItem()->getParentItem()): ?>
            data-th="<?= $block->escapeHtmlAttr($attributes['option_label']) ?>"
        <?php endif; ?>>
    <?php if (!$_item->getOrderItem()->getParentItem()): ?>
        <td class="name px-4 py-3 align-top text-neutral-800" data-th="<?= $block->escapeHtmlAttr(__('Product Name')) ?>">
            <strong class="product name text-base font-semibold leading-snug text-neutral-900"><?= $block->escapeHtml($_item->getName()) ?></strong>
        </td>
    <?php else: ?>
        <td class="value px-4 py-3 align-top text-sm text-neutral-800" data-th="<?= $block->escapeHtmlAttr(__('Product Name')) ?>"><?= $block->getValueHtml($_item) ?></td>
    <?php endif; ?>
    <td class="sku px-4 py-3 align-top text-sm text-neutral-700" data-th="<?= $block->escapeHtmlAttr(__('SKU')) ?>"><?= $block->escapeHtml($_item->getSku()) ?></td>
    <td class="px-4 py-3 align-top text-sm font-medium text-neutral-900" data-th="<?= $block->escapeHtmlAttr(__('Price')) ?>">
        <?php if ($block->canShowPriceInfo($_item)): ?>
            <?= $block->getItemPriceHtml($_item) ?>
        <?php else: ?>
            &nbsp;
        <?php endif; ?>
    </td>
    <td class="px-4 py-3 align-top text-center text-sm tabular-nums text-neutral-800" data-th="<?= $block->escapeHtmlAttr(__('Qty Invoiced')) ?>">
        <?php if ($block->canShowPriceInfo($_item)): ?>
            <?= /* @noEscape */ $localeFormatter->formatNumber((float)$_item->getQty() * 1) ?>
        <?php else: ?>
            &nbsp;
        <?php endif; ?>
    </td>
    <td class="subtotal px-4 py-3 align-top text-sm font-medium text-neutral-900" data-th="<?= $block->escapeHtmlAttr(__('Subtotal')) ?>">
        <?php if ($block->canShowPriceInfo($_item)): ?>
            <?= $block->getItemRowTotalHtml($_item) ?>
            <?php else: ?>
                &nbsp;
            <?php endif; ?>
        </td>
    </tr>
<?php endforeach; ?>

<?php if ($_showlastRow && (($_options = $block->getItemOptions()) || $block->escapeHtml($_item->getDescription()))): ?>
    <tr>
        <td class="options border-b border-neutral-200 px-4 py-3 align-top text-sm" colspan="5">
            <?php if ($_options = $block->getItemOptions()): ?>
                <dl class="item-options space-y-1 text-xs text-neutral-600">
                    <?php foreach ($_options as $_option): ?>
                        <dt class="font-medium text-neutral-800"><?= $block->escapeHtml($_option['label']) ?></dt>
                        <?php if (!$block->getPrintStatus()): ?>
                            <?php $_formatedOptionValue = $block->getFormatedOptionValue($_option) ?>
                            <dd<?php if (isset($_formatedOptionValue['full_view'])): ?> class="inline-block w-full"<?php endif; ?>>
                                <?= /* @noEscape */ $_formatedOptionValue['value'] ?>
                                <?php if (isset($_formatedOptionValue['full_view'])): ?>
                                    <div class="content inline-block">
                                        <dl class="options mt-2 rounded-lg border border-neutral-200 bg-white p-3">
                                            <dt class="font-medium text-neutral-800"><?= $block->escapeHtml($_option['label']) ?></dt>
                                            <dd class="mt-1"><?= /* @noEscape */ $_formatedOptionValue['full_view'] ?></dd>
                                        </dl>
                                    </div>
                                <?php endif; ?>
                            </dd>
                        <?php else: ?>
                            <dd><?= $block->escapeHtml((isset($_option['print_value']) ? $_option['print_value']: $_option['value'])) ?></dd>
                        <?php endif; ?>
                    <?php endforeach; ?>
                </dl>
            <?php endif; ?>
            <?= $block->escapeHtml($_item->getDescription()) ?>
        </td>
    </tr>
<?php endif; ?>
