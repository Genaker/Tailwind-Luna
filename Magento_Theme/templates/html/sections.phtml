<?php
/**
 * Mobile drawer: Menu / Account / Settings as exclusive <details name> (no mage.tabs).
 *
 * Native details/summary avoids tablist + interleaved tabpanels and role="tab" + aria-expanded
 * mismatches from mage.collapsible. Same group name keeps one section open at a time (modern browsers).
 *
 * CSS Grid: --nav-sections-tab-count; titles row 1 / panel row 2 (see navigation.scss).
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
$group = $block->getGroupName();
$layout = $block->getLayout();
$sectionEntries = [];
if ($detailedInfoGroup = $block->getGroupChildNames($group)) {
    foreach ($detailedInfoGroup as $name) {
        $html = $layout->renderElement($name);
        if (!($html !== null && trim($html)) && ($block->getUseForce() != true)) {
            continue;
        }
        $alias = $layout->getElementAlias($name);
        $sectionEntries[] = [
            'alias' => $alias,
            'label' => $block->getChildData($alias, 'title'),
            'html' => $html,
        ];
    }
}
$tabCount = count($sectionEntries);
$hasStoreMenu = false;
foreach ($sectionEntries as $e) {
    if ($e['alias'] === 'store.menu') {
        $hasStoreMenu = true;
        break;
    }
}
?>
<?php if ($tabCount > 0): ?>
    <div class="sections nav-sections flex w-full flex-col border-b border-neutral-200 bg-white">
        <header class="nav-drawer-header flex shrink-0 items-center justify-between gap-3 border-b border-neutral-200 bg-neutral-50/95 px-3 py-2.5 backdrop-blur-sm lg:hidden">
            <p class="m-0 text-sm font-semibold tracking-tight text-neutral-900"><?= $block->escapeHtml(__('Menu')) ?></p>
            <button type="button"
                    class="nav-drawer-close inline-flex h-9 w-9 shrink-0 cursor-pointer items-center justify-center rounded-lg border border-neutral-200 bg-white text-xl font-light leading-none text-neutral-700 shadow-sm touch-manipulation transition-colors duration-150 hover:border-neutral-300 hover:bg-neutral-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/25 focus-visible:ring-offset-1 active:bg-neutral-100"
                    data-action="toggle-nav"
                    aria-label="<?= $block->escapeHtmlAttr(__('Close menu')) ?>">
                <span class="pointer-events-none flex h-full w-full items-center justify-center pb-0.5" aria-hidden="true">&times;</span>
            </button>
        </header>
        <nav class="nav-sections-nav"
             aria-label="<?= $block->escapeHtmlAttr(__('Store sections')) ?>">
            <div class="section-items nav-sections-items min-h-0 flex-1"
                 style="--nav-sections-tab-count: <?= (int) $tabCount ?>">
            <?php foreach ($sectionEntries as $idx => $entry): ?>
                <?php
                $alias = $entry['alias'];
                $isMenu = $alias === 'store.menu';
                $openOnLoad = $hasStoreMenu ? $isMenu : ($idx === 0);
                $desktopVisible = $hasStoreMenu ? $isMenu : ($idx === 0);
                ?>
                <details class="nav-section-detail<?= $desktopVisible ? ' nav-section-detail--desktop-visible' : '' ?>"
                         name="store-sections"
                         <?= $openOnLoad ? 'open' : '' ?>>
                    <summary class="section-item-title nav-sections-item-title box-border flex min-h-[3.5rem] cursor-pointer list-none items-center justify-center border border-solid border-neutral-200 border-l-0 border-t-0 bg-neutral-100 px-1 py-2 text-center text-xs font-semibold uppercase tracking-wide text-neutral-600 transition-colors first:border-l-0 marker:content-[''] hover:bg-neutral-50 active:bg-neutral-100 sm:px-2 sm:text-sm [&::-webkit-details-marker]:hidden">
                        <?= $block->escapeHtml($entry['label']) ?>
                    </summary>
                    <div class="section-item-content nav-sections-item-content box-border w-full bg-white px-3 pb-8 pt-3 sm:px-4"
                         id="<?= $block->escapeHtmlAttr($alias) ?>"
                         tabindex="-1">
                        <?= /* @noEscape */ $entry['html'] ?>
                    </div>
                </details>
            <?php endforeach; ?>
            </div>
        </nav>
    </div>
<?php endif; ?>
