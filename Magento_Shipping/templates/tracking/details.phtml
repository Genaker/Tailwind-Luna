declare(strict_types=1);

/** @var \Magento\Framework\View\Element\Template $block */
// phpcs:disable Magento2.Files.LineLength.MaxExceeded

$parentBlock = $block->getParentBlock();
$track = $block->getData('track');
$email = $block->getData('storeSupportEmail');
$fields = [
    'Status' => 'getStatus',
    'Signed by' => 'getSignedby',
    'Delivered to' => 'getDeliveryLocation',
    'Shipped or billed on' => 'getShippedDate',
    'Service Type' => 'getService',
    'Weight' => 'getWeight',
];
$number = is_object($track) ? $track->getTracking() : $track['number'];
?>
<div class="overflow-x-auto rounded-lg border border-neutral-200">
<table class="table data order tracking w-full border-collapse text-sm" id="tracking-table-popup-<?= $block->escapeHtmlAttr((string) $number) ?>">
    <caption class="sr-only"><?= $block->escapeHtml(__('Order tracking')) ?></caption>
    <tbody>
    <?php if (is_object($track)) : ?>
        <tr class="border-b border-neutral-200 last:border-b-0">
            <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-800 align-top w-1/3" scope="row"><?= $block->escapeHtml(__('Tracking Number:')) ?></th>
            <td class="value px-4 py-3 align-top"><?= $block->escapeHtml($number) ?></td>
        </tr>
        <?php if ($track->getCarrierTitle()) : ?>
            <tr class="border-b border-neutral-200 last:border-b-0">
                <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-800 align-top" scope="row"><?= $block->escapeHtml(__('Carrier:')) ?></th>
                <td class="value px-4 py-3 align-top"><?= $block->escapeHtml($track->getCarrierTitle()) ?></td>
            </tr>
        <?php endif; ?>
        <?php if ($track->getErrorMessage()) : ?>
            <tr class="border-b border-neutral-200 last:border-b-0">
                <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-800 align-top" scope="row"><?= $block->escapeHtml(__('Error:')) ?></th>
                <td class="px-4 py-3 align-top border-red-200 bg-red-50 text-red-900">
                    <?= $block->escapeHtml(__('Tracking information is currently not available. Please ')) ?>
                    <?php if ($parentBlock->getContactUsEnabled()) : ?>
                        <a href="<?= $block->escapeUrl($parentBlock->getContactUs()) ?>" target="_blank"
                           rel="noopener noreferrer"
                           class="font-medium underline hover:no-underline"
                           title="<?= $block->escapeHtmlAttr(__('contact us')) ?>">
                            <?= $block->escapeHtml(__('contact us')) ?>
                        </a>
                        <?= $block->escapeHtml(__(' for more information or ')) ?>
                    <?php endif; ?>
                    <?= $block->escapeHtml(__('email us at ')) ?>
                    <a href="<?= $block->escapeUrl('mailto:' . $email) ?>" class="font-medium underline hover:no-underline"><?= $block->escapeHtml($email) ?></a>
                </td>
            </tr>
        <?php elseif ($track->getTrackSummary()) : ?>
            <tr class="border-b border-neutral-200 last:border-b-0">
                <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-800 align-top" scope="row"><?= $block->escapeHtml(__('Info:')) ?></th>
                <td class="value px-4 py-3 align-top"><?= $block->escapeHtml($track->getTrackSummary()) ?></td>
            </tr>
        <?php elseif ($track->getUrl()) : ?>
            <tr class="border-b border-neutral-200 last:border-b-0">
                <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-800 align-top" scope="row"><?= $block->escapeHtml(__('Track:')) ?></th>
                <td class="value px-4 py-3 align-top">
                    <a href="<?= $block->escapeUrl($track->getUrl()) ?>" target="_blank" rel="noopener noreferrer" class="font-medium text-blue-600 hover:text-blue-800 hover:underline">
                        <?= $block->escapeUrl($track->getUrl()) ?>
                    </a>
                </td>
            </tr>
        <?php else : ?>
            <?php foreach ($fields as $title => $property) : ?>
                <?php if (!empty($track->$property())) : ?>
                    <tr class="border-b border-neutral-200 last:border-b-0">
                        <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-800 align-top" scope="row"><?= $block->escapeHtml(__($title . ':')) ?></th>
                        <td class="value px-4 py-3 align-top"><?= $block->escapeHtml($track->$property()) ?></td>
                    </tr>
                <?php endif;?>
            <?php endforeach; ?>

            <?php if ($track->getDeliverydate()) : ?>
                <tr class="border-b border-neutral-200 last:border-b-0">
                    <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-800 align-top" scope="row"><?= $block->escapeHtml($parentBlock->getDeliveryDateTitle()->getTitle($track)) ?></th>
                    <td class="value px-4 py-3 align-top">
                        <?= /* @noEscape */ $parentBlock->formatDeliveryDateTime($track->getDeliverydate(), $track->getDeliverytime()) ?>
                    </td>
                </tr>
            <?php endif; ?>
        <?php endif; ?>
    <?php elseif (isset($track['title'], $track['number']) && $track['number']) : ?>
        <?php /* if the tracking is custom value */ ?>
        <tr class="border-b border-neutral-200 last:border-b-0">
            <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-800 align-top" scope="row">
                <?= ($track['title'] ? $block->escapeHtml($track['title']) : $block->escapeHtml(__('N/A'))) ?>:
            </th>
            <td class="value px-4 py-3 align-top"><?= (isset($track['number']) ? $block->escapeHtml($track['number']) : '') ?></td>
        </tr>
    <?php endif; ?>
    </tbody>
</table>
</div>
