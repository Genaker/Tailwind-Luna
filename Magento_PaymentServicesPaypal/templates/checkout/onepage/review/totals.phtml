declare(strict_types=1);

?>

<?php
/** @var \Magento\Checkout\Block\Cart\Totals $block */
/** @var \Magento\Framework\Escaper $escaper */
?>

<?php if ($block->getTotals()) : ?>
    <?php $colspan = 3; ?>
    <?= /* @noEscape */ $block->renderTotals(null, $colspan) ?>
    <?= /* @noEscape */ $block->renderTotals('footer', $colspan) ?>
    <?php if ($block->needDisplayBaseGrandtotal()) : ?>
    <tr class="totals charge border-b border-neutral-200">
        <th class="mark px-4 py-3 text-left text-sm font-medium text-neutral-800" colspan="<?= /* @noEscape */ $colspan ?>" scope="row">
            <?= $escaper->escapeHtml(__('Your credit card will be charged for')) ?>
        </th>
        <td class="amount px-4 py-3 text-right text-sm font-medium tabular-nums text-neutral-900" data-th="<?= $escaper->escapeHtmlAttr(__('Your credit card will be charged for')) ?>">
            <?= /* @noEscape */ $block->displayBaseGrandtotal() ?>
        </td>
    </tr>
    <?php endif ?>
<?php endif ?>
