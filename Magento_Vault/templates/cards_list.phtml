/** @var \Magento\Vault\Block\Customer\CreditCards $block */
$tokens = $block->getPaymentTokens();
?>
<?php if (count($tokens) !== 0) : ?>
    <div class="my-credit-cards overflow-x-auto rounded-lg border border-neutral-200">
        <table class="table data table-credit-cards w-full border-collapse text-sm" id="my-orders-table">
            <caption class="sr-only"><?= $block->escapeHtml(__('Stored Payment Methods')) ?></caption>
            <thead>
            <tr class="border-b border-neutral-200 bg-neutral-50">
                <th scope="col" class="card-number px-4 py-3 text-left text-sm font-semibold text-neutral-800"><?= $block->escapeHtml(__('Card Number')) ?></th>
                <th scope="col" class="expire px-4 py-3 text-left text-sm font-semibold text-neutral-800"><?= $block->escapeHtml(__('Expiration Date')) ?></th>
                <th scope="col" class="card-type px-4 py-3 text-left text-sm font-semibold text-neutral-800"><?= $block->escapeHtml(__('Type')) ?></th>
                <th scope="col" class="px-4 py-3 text-right text-sm font-semibold text-neutral-800"><?= $block->escapeHtml(__('Actions')) ?></th>
            </tr>
            </thead>
            <tbody>
            <?php foreach ($tokens as $token) : ?>
                <?= $block->renderTokenHtml($token) ?>
            <?php endforeach; ?>
            </tbody>
        </table>
    </div>

<?php elseif (!$block->isExistsCustomerTokens()) : ?>
    <div class="mb-4 rounded-lg border border-neutral-200 bg-neutral-50 p-4 text-sm text-neutral-700 empty">
        <span><?= $block->escapeHtml(__('You have no stored payment methods.')) ?></span>
    </div>
<?php endif ?>
