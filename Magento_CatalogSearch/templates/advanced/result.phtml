?>
<?php
/**
 * @var $block \Magento\CatalogSearch\Block\Advanced\Result
 */
/** this changes need for valid apply filters and configuration before search process is started */
$productList = $block->getProductListHtml();
?>
<?php if ($results = $block->getResultCount()) : ?>
    <div class="search found mb-4 text-sm text-neutral-800">
        <?php if ($results == 1) : ?>
            <?= /* @noEscape */ __('<strong>%1 item</strong> were found using the following search criteria', $results) ?>
        <?php else : ?>
            <?= /* @noEscape */ __('<strong>%1 items</strong> were found using the following search criteria', $results) ?>
        <?php endif; ?>
    </div>
<?php else : ?>
    <div role="alert" class="mb-6 rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-900">
        <div>
            <?= $block->escapeHtml(__('We can\'t find any items matching these search criteria.')) ?>
            <a class="font-semibold text-red-800 underline hover:text-red-950" href="<?= $block->escapeUrl($block->getFormUrl()) ?>"><?= $block->escapeHtml(__('Modify your search.')) ?></a>
        </div>
    </div>
<?php endif; ?>

<?php $searchCriterias = $block->getSearchCriterias(); ?>
<div class="search summary mb-6 flex flex-col gap-4 md:flex-row md:gap-8">
    <?php foreach (['left', 'right'] as $side) : ?>
        <?php if (!empty($searchCriterias[$side])) : ?>
            <ul class="m-0 min-w-0 flex-1 list-none p-0">
                <?php foreach ($searchCriterias[$side] as $criteria) : ?>
                    <li class="flex flex-wrap gap-x-2 border-b border-neutral-100 py-2 text-sm last:border-b-0">
                        <strong class="text-neutral-900"><?= $block->escapeHtml(__($criteria['name'])) ?>:</strong>
                        <span class="text-neutral-700"><?= $block->escapeHtml($criteria['value']) ?></span>
                    </li>
                <?php endforeach; ?>
            </ul>
        <?php endif; ?>
    <?php endforeach; ?>
</div>
<?php if ($block->getResultCount()) : ?>
    <div class="mb-6 rounded-lg border border-blue-200 bg-blue-50 p-4 text-sm text-blue-900">
        <div>
            <?= $block->escapeHtml(__("Don't see what you're looking for?")) ?>
            <a class="font-semibold text-blue-800 underline hover:text-blue-950" href="<?= $block->escapeUrl($block->getFormUrl()) ?>"><?= $block->escapeHtml(__('Modify your search.')) ?></a>
        </div>
    </div>
<?php endif; ?>
<?php if ($block->getResultCount()) : ?>
    <div class="search results"><?= /* @noEscape */ $productList ?></div>
<?php endif; ?>
