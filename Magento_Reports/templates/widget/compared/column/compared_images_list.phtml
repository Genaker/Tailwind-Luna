?>
<?php
if ($exist = $block->getRecentlyComparedProducts()) {
    $type = 'widget-compared';

    $image = 'cart_page_product_thumbnail';
    $title = __('Recently Compared');
    $items = $exist;

    $showWishlist = false;
    $showCompare = false;
    $showCart = false;
    $rating = false;
    $description = false;
}
?>
<?php if ($exist) : ?>
<div class="mb-8 widget">
    <div class="text-lg font-semibold text-neutral-900 mb-3 pb-2 border-b border-neutral-200">
        <strong><?= $block->escapeHtml($title) ?></strong>
    </div>
    <div class="text-sm text-neutral-700">
        <ol id="widget-compared-<?= $block->escapeHtmlAttr($block->getNameInLayout()) ?>" class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3 list-none p-0 m-0 product-items-images">
        <?php foreach ($items as $_product) : ?>
            <li class="flex flex-col border border-neutral-200 rounded-lg bg-white overflow-hidden">
                <a class="block overflow-hidden bg-neutral-100" href="<?= $block->escapeUrl($_product->getProductUrl()) ?>"
                    title="<?= $block->escapeHtmlAttr($block->stripTags($_product->getName(), null, true)) ?>">
                    <?= $block->getImage($_product, $image)->toHtml() ?>
                </a>
            </li>
        <?php endforeach; ?>
        </ol>
    </div>
</div>
<?php endif; ?>
