/**
 * @deprecated
 * @var \Magento\Catalog\Block\Product\Compare\ListCompare $block
 */
if ($exist = $block->getRecentlyComparedProducts()) {
    $type = 'widget-compared';
    $mode = 'grid';

    $type = $type . '-' . $mode;

    $image = 'category_page_grid';
    $title = __('Recently Compared');
    $items = $exist;

    $showWishlist = true;
    $showCompare = true;
    $showCart = true;
    $rating = 'short';
    $description = ($mode == 'list') ? true : false;

    $postDataHelper = $this->helper(\Magento\Framework\Data\Helper\PostHelper::class);
    $wishlistHelper = $this->helper(\Magento\Wishlist\Helper\Data::class);
    $compareHelper = $this->helper(\Magento\Catalog\Helper\Product\Compare::class);
}
?>

<?php if ($exist) : ?>
    <div class="block widget block-compared-products-<?= $block->escapeHtmlAttr($mode) ?>">
        <div class="text-lg font-semibold text-neutral-900 mb-3 pb-2 border-b border-neutral-200">
            <strong role="heading" aria-level="2"><?= $block->escapeHtml($title) ?></strong>
        </div>
        <div class="text-sm text-neutral-700">
            <?= '<!-- ' . $block->escapeHtml($image) . '-->' ?>
            <div class="products-<?= $block->escapeHtmlAttr($mode) ?> <?= $block->escapeHtmlAttr($mode) ?>">
                <ol class="product-items <?= $block->escapeHtmlAttr($type)?>">
                    <?php foreach ($items as $_item) : ?>
                        <li class="flex flex-col border border-neutral-200 rounded-lg bg-white overflow-hidden">
                            <div class="flex flex-col gap-3 p-4">
                                <a href="<?= $block->escapeUrl($block->getProductUrl($_item)) ?>" class="block overflow-hidden bg-neutral-100">
                                    <?= $block->getImage($_item, $image)->toHtml() ?>
                                </a>
                                <div class="flex flex-col gap-2 px-4 pb-4">
                                    <strong class="text-base font-semibold leading-snug">
                                        <a title="<?= $block->escapeHtmlAttr($_item->getName()) ?>"
                                           href="<?= $block->escapeUrl($block->getProductUrl($_item)) ?>" class="text-blue-600 hover:text-blue-800 hover:underline">
                                            <?= $block->escapeHtml($_item->getName()) ?>
                                        </a>
                                    </strong>
                                    <?= /* @noEscape */ $block->getProductPriceHtml(
                                        $_item,
                                        \Magento\Catalog\Pricing\Price\FinalPrice::PRICE_CODE,
                                        \Magento\Framework\Pricing\Render::ZONE_ITEM_LIST,
                                        [
                                            'price_id_suffix' => '-' . $type
                                        ]
                                    ) ?>
                                    <?php if ($rating) : ?>
                                        <?= $block->getReviewsSummaryHtml($_item, $rating) ?>
                                    <?php endif; ?>
                                    <?php if ($showWishlist || $showCompare || $showCart) : ?>
                                        <div class="flex flex-wrap items-center gap-2">
                                            <?php if ($showCart) : ?>
                                                <div class="flex flex-wrap gap-2">
                                                    <?php if ($_item->isSaleable()) : ?>
                                                        <?php if ($_item->getTypeInstance()->hasRequiredOptions($_item)) : ?>
                                                            <button class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold border px-4 py-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:opacity-50 disabled:pointer-events-none bg-blue-600 text-white border-blue-600 hover:bg-blue-700 tocart"
                                                                    data-mage-init='{"redirectUrl": {"url": "<?= $block->escapeJs($block->escapeUrl($block->getAddToCartUrl($_item))) ?>"}}'
                                                                    type="button" title="<?= $block->escapeHtmlAttr(__('Add to Cart')) ?>">
                                                                <span><?= $block->escapeHtml(__('Add to Cart')) ?></span>
                                                            </button>
                                                        <?php else : ?>
                                                            <?php
                                                                $postData = $postDataHelper->getPostData($block->getAddToCartUrl($_item), ['product' => $_item->getEntityId()])
                                                            ?>
                                                            <button class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold border px-4 py-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:opacity-50 disabled:pointer-events-none bg-blue-600 text-white border-blue-600 hover:bg-blue-700 tocart"
                                                                    data-post='<?= /* @noEscape */ $postData ?>'
                                                                    type="button" title="<?= $block->escapeHtmlAttr(__('Add to Cart')) ?>">
                                                                <span><?= $block->escapeHtml(__('Add to Cart')) ?></span>
                                                            </button>
                                                        <?php endif; ?>
                                                    <?php else : ?>
                                                        <?php if ($_item->isAvailable()) : ?>
                                                            <div class="text-sm text-green-700"><span><?= $block->escapeHtml(__('In stock')) ?></span></div>
                                                        <?php else : ?>
                                                            <div class="text-sm text-red-700"><span><?= $block->escapeHtml(__('Out of stock')) ?></span></div>
                                                        <?php endif; ?>
                                                    <?php endif; ?>
                                                </div>
                                            <?php endif; ?>

                                            <?php if ($showWishlist || $showCompare) : ?>
                                                <div class="flex flex-wrap gap-2 text-sm text-neutral-600" data-role="add-to-links">
                                                    <?php if ($wishlistHelper->isAllow() && $showWishlist) : ?>
                                                        <a href="#"
                                                           data-post='<?= /* @noEscape */ $block->getAddToWishlistParams($_item) ?>'
                                                           data-action="add-to-wishlist"
                                                           class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold border border-neutral-300 px-4 py-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:opacity-50 disabled:pointer-events-none towishlist"
                                                           title="<?= $block->escapeHtmlAttr(__('Add to Wish List')) ?>">
                                                            <span><?= $block->escapeHtml(__('Add to Wish List')) ?></span>
                                                        </a>
                                                    <?php endif; ?>
                                                    <?php if ($block->getAddToCompareUrl() && $showCompare) : ?>
                                                        <a href="#" class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold border border-neutral-300 px-4 py-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:opacity-50 disabled:pointer-events-none tocompare"
                                                           data-post='<?= /* @noEscape */ $compareHelper->getPostDataParams($_item) ?>'
                                                           title="<?= $block->escapeHtmlAttr(__('Add to Compare')) ?>">
                                                            <span><?= $block->escapeHtml(__('Add to Compare')) ?></span>
                                                        </a>
                                                    <?php endif; ?>
                                                </div>
                                            <?php endif; ?>
                                        </div>
                                    <?php endif; ?>
                                </div>
                            </div>
                        </li>
                    <?php endforeach ?>
                </ol>
            </div>
            <?= $block->getPagerHtml() ?>
        </div>
    </div>
<?php endif;?>
