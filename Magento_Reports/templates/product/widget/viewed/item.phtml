declare(strict_types=1);

/**
 * @deprecated
 * @var \Magento\Reports\Block\Product\Widget\Viewed\Item $block
 */

$type = $block->getType() . '-' . $block->getViewMode();

$item = $block->getProduct();

$image = $block->getImageType();
$rating = 'short';

$postDataHelper = $this->helper(\Magento\Framework\Data\Helper\PostHelper::class);
$wishlistHelper = $this->helper(\Magento\Wishlist\Helper\Data::class);
$compareHelper = $this->helper(\Magento\Catalog\Helper\Product\Compare::class);
?>
<div class="mb-6" id="widget_viewed_item" data-sku="<?= $block->escapeHtmlAttr($item->getSku()) ?>" style="display: none;">
    <li class="flex flex-col border border-neutral-200 rounded-lg bg-white overflow-hidden product">
        <div class="product">
            <?= '<!-- ' . $block->escapeHtml($image) . '-->' ?>
            <a href="<?= $block->escapeUrl($block->getProductUrl($item)) ?>" class="product photo block">
                <?= $block->getImage($item, $image)->toHtml() ?>
            </a>
            <div class="text-sm product p-3">
                <strong class="product name"><a title="<?= $block->escapeHtmlAttr($item->getName()) ?>" class="text-blue-600 hover:text-blue-800 hover:underline" href="<?= $block->escapeUrl($block->getProductUrl($item)) ?>">
                    <?= $block->escapeHtml($item->getName()) ?></a>
                </strong>

                <?= /* @noEscape */ $block->getProductPriceHtml(
                    $item,
                    \Magento\Catalog\Pricing\Price\FinalPrice::PRICE_CODE,
                    \Magento\Framework\Pricing\Render::ZONE_ITEM_LIST,
                    [
                        'price_id_suffix' => '-' . $type
                    ]
                ) ?>

                <?php if ($rating) : ?>
                    <?= $block->getReviewsSummaryHtml($item, $rating) ?>
                <?php endif; ?>

                <div class="mt-3 flex flex-wrap gap-2 product">
                    <?php if ($item->isSaleable()) : ?>
                        <?php if ($item->getTypeInstance()->hasRequiredOptions($item)) : ?>
                            <button class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold border px-4 py-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:opacity-50 disabled:pointer-events-none bg-blue-600 text-white border-blue-600 hover:bg-blue-700 tocart" data-mage-init='{"redirectUrl": {"url": "<?= $block->escapeJs($block->escapeUrl($block->getAddToCartUrl($item))) ?>"}}' type="button" title="<?= $block->escapeHtmlAttr(__('Add to Cart')) ?>">
                                <span><?= $block->escapeHtml(__('Add to Cart')) ?></span>
                            </button>
                        <?php else : ?>
                            <?php $postData = $postDataHelper->getPostData($block->getAddToCartUrl($item), ['product' => $item->getEntityId()])
                            ?>
                            <button class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold border px-4 py-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:opacity-50 disabled:pointer-events-none bg-blue-600 text-white border-blue-600 hover:bg-blue-700 tocart"
                                    data-post='<?= /* @noEscape */ $postData ?>'
                                    type="button" title="<?= $block->escapeHtmlAttr(__('Add to Cart')) ?>">
                                <span><?= $block->escapeHtml(__('Add to Cart')) ?></span>
                            </button>
                        <?php endif; ?>
                    <?php else : ?>
                        <?php if ($item->isAvailable()) : ?>
                            <div class="text-sm text-green-700"><span><?= $block->escapeHtml(__('In stock')) ?></span></div>
                        <?php else : ?>
                            <div class="text-sm text-red-700"><span><?= $block->escapeHtml(__('Out of stock')) ?></span></div>
                        <?php endif; ?>
                    <?php endif; ?>

                    <div class="secondary-addto-links flex flex-wrap gap-2" data-role="add-to-links">
                        <?php if ($wishlistHelper->isAllow()) : ?>
                            <a href="#" data-post='<?= /* @noEscape */ $block->getAddToWishlistParams($item) ?>'  class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold border border-neutral-300 px-4 py-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:opacity-50 disabled:pointer-events-none towishlist" data-action="add-to-wishlist" title="<?= $block->escapeHtmlAttr(__('Add to Wish List')) ?>">
                                <span><?= $block->escapeHtml(__('Add to Wish List')) ?></span>
                            </a>
                        <?php endif; ?>
                        <?php if ($block->getAddToCompareUrl()) : ?>
                            <a href="#" class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold border border-neutral-300 px-4 py-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:opacity-50 disabled:pointer-events-none tocompare"
                               data-post='<?= /* @noEscape */ $compareHelper->getPostDataParams($item) ?>'
                               data-role="add-to-links"
                               title="<?= $block->escapeHtmlAttr(__('Add to Compare')) ?>">
                                <span><?= $block->escapeHtml(__('Add to Compare')) ?></span>
                            </a>
                        <?php endif; ?>
                    </div>
                </div>
            </div>
        </div>
    </li>
</div>
