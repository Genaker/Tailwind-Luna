use Magento\Framework\Escaper;
use Magento\Framework\View\Helper\SecureHtmlRenderer;
use Magento\Paypal\Block\Express\Review;

/**
 * @var Review $block
 * @var Escaper $escaper
 * @var SecureHtmlRenderer $secureRenderer
 */

/** @var \Magento\Paypal\ViewModel\PaypalFundingSourceDataProvider $paypalFundingSourceDataProvider */
$paypalFundingSourceDataProvider = $block->getData('PaypalFundingSourceDataProvider');
?>
<div class="paypal-review view">
    <div class="mb-8">
        <div class="text-sm text-neutral-700">
            <?php if ($block->getShippingAddress()): ?>
                <div class="mb-6 rounded-lg border border-neutral-200 bg-white box-order-shipping-method">
                    <strong class="px-4 py-3 text-base font-semibold border-b border-neutral-200 bg-neutral-50">
                        <span><?= $escaper->escapeHtml(__('Shipping Method')) ?></span>
                    </strong>
                    <div class="p-4">
                        <form method="post" id="shipping-method-form"
                              action="<?= $escaper->escapeUrl($block->getShippingMethodSubmitUrl()) ?>"
                              class="form">
                            <?php if ($block->canEditShippingMethod()): ?>
                                <?php if ($groups = $block->getShippingRateGroups()): ?>
                                    <?php $currentRate = $block->getCurrentShippingRate(); ?>
                                    <div class="mb-4 shipping required">
                                        <select name="shipping_method" id="shipping-method" class="w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                                            <?php if (!$currentRate): ?>
                                                <option value="">
                                                    <?= $escaper->escapeHtml(
                                                        __('Please select a shipping method...')
                                                    ); ?>
                                                </option>
                                            <?php endif; ?>
                                            <?php foreach ($groups as $code => $rates): ?>
                                                <optgroup label="<?=
                                                    $escaper->escapeHtml($block->getCarrierName($code));
                                                ?>">
                                                    <?php foreach ($rates as $rate): ?>
                                                        <option value="<?=
                                                                        $block->escapeHtml(
                                                                            $block->renderShippingRateValue($rate)
                                                                        );
                                                                        ?>"
                                                            <?= ($currentRate === $rate) ?
                                                                ' selected="selected"' : '';
                                                            ?>>
                                                            <?= /* @noEscape */ $block->renderShippingRateOption($rate);
                                                            ?>
                                                        </option>
                                                    <?php endforeach; ?>
                                                </optgroup>
                                            <?php endforeach; ?>
                                        </select>
                                    </div>
                                <?php else: ?>
                                    <p>
                                        <?= $escaper->escapeHtml(__(
                                            'Sorry, no quotes are available for this order right now.'
                                        )); ?>
                                    </p>
                                <?php endif; ?>
                            <?php else: ?>
                                <p>
                                    <?= /* @noEscape */ $block->renderShippingRateOption(
                                        $block->getCurrentShippingRate()
                                    ); ?>
                                </p>
                            <?php endif; ?>
                        </form>
                    </div>
                </div>
                <div class="mb-6 rounded-lg border border-neutral-200 bg-white box-order-shipping-address">
                    <strong class="px-4 py-3 text-base font-semibold border-b border-neutral-200 bg-neutral-50">
                        <span><?= $escaper->escapeHtml(__('Shipping Address')) ?></span>
                    </strong>
                    <div class="p-4">
                        <address>
                            <?= $escaper->escapeHtml(
                                $block->renderAddress($block->getShippingAddress()),
                                ['br']
                            ); ?>
                        </address>
                    </div>
                    <?php if ($block->getCanEditShippingAddress()): ?>
                        <div class="px-4 py-3 border-t border-neutral-200 flex flex-wrap gap-2 justify-end">
                            <a href="<?= $escaper->escapeUrl($block->getEditUrl()) ?>" class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold border px-4 py-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:opacity-50 disabled:pointer-events-none edit">
                                <span><?= $escaper->escapeHtml(__('Edit')) ?></span>
                            </a>
                        </div>
                    <?php endif; ?>
                </div>
            <?php endif; ?>
            <div class="mb-6 rounded-lg border border-neutral-200 bg-white box-order-billing-address">
                <strong class="px-4 py-3 text-base font-semibold border-b border-neutral-200 bg-neutral-50"><span><?= $escaper->escapeHtml(__('Payment Method')) ?></span></strong>
                <div class="p-4">
                    <?= $escaper->escapeHtml($paypalFundingSourceDataProvider->getPaypalFundingSource()
                        ?? $block->getPaymentMethodTitle()) ?><br>
                    <?= $escaper->escapeHtml($block->getEmail()) ?> <br>
                    <img src="https://www.paypalobjects.com/webstatic/en_US/i/buttons/pp-acceptance-medium.png"
                         alt="<?= $block->escapeHtml(__('Buy now with PayPal')) ?>"/>
                </div>
                <?php if ($block->getEditUrl()): ?>
                    <div class="px-4 py-3 border-t border-neutral-200 flex flex-wrap gap-2 justify-end">
                        <a href="<?= $escaper->escapeUrl($block->getEditUrl()) ?>" class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold border px-4 py-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:opacity-50 disabled:pointer-events-none edit">
                            <span><?= $escaper->escapeHtml(__('Edit Payment Information')) ?></span>
                        </a>
                    </div>
                <?php endif ?>
            </div>
        </div>
    </div>

    <div class="paypal-review-discount">
        <?= $block->getChildHtml('paypal.additional.actions') ?>
    </div>

    <div class="paypal-review-items">
        <div class="paypal-review-title mb-4 flex flex-wrap items-center justify-between gap-3 border-b border-neutral-200 pb-3">
            <strong class="text-base font-semibold text-neutral-900"><?= $escaper->escapeHtml(__('Items in Your Shopping Cart')) ?></strong>
            <a href="<?= $escaper->escapeUrl($block->getUrl('checkout/cart')) ?>" class="edit inline-flex items-center justify-center gap-2 rounded-md border border-neutral-300 bg-white px-4 py-2 text-sm font-semibold text-neutral-900 transition-colors hover:bg-neutral-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:pointer-events-none disabled:opacity-50">
                <span><?= $escaper->escapeHtml(__('Edit Shopping Cart')) ?></span>
            </a>
        </div>

        <?= $block->getChildHtml('details') ?>

        <form method="post" id="order-review-form" action="<?= $escaper->escapeUrl($block->getPlaceOrderUrl()) ?>"
              class="form order-review-form">
            <?= $block->getChildHtml('agreements') ?>
            <div class="clear-both flex flex-wrap items-center justify-between gap-4 py-4" id="review-buttons-container">
                <button type="button" id="review-button" class="checkout inline-flex items-center justify-center gap-2 rounded-md border border-blue-600 bg-blue-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-blue-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-600 disabled:pointer-events-none disabled:opacity-50"
                        value="<?= $escaper->escapeHtml(__('Place Order')) ?>">
                    <span><?= $escaper->escapeHtml(__('Place Order')) ?></span>
                </button>
                <span class="please-wait load indicator" id="review-please-wait"
                      data-text="<?= $escaper->escapeHtml(__('Submitting order information...')) ?>">
                   <span><?= $escaper->escapeHtml(__('Submitting order information...')) ?></span>
                </span>
                <?= /* @noEscape */ $secureRenderer->renderStyleAsTag("display: none;", 'span#review-please-wait') ?>
            </div>
        </form>
    </div>
</div>
<?php // phpcs:ignore Magento2.Legacy.PhtmlTemplate ?>
<script type="text/x-magento-init">
    {
        "#order-review-form": {
            "validation": {},
            "orderReview": {
                "shippingSubmitFormSelector": "#shipping-method-form",
                "shippingSelector": "#shipping-method",
                "shippingMethodUpdateUrl": "<?= $escaper->escapeJs($block->getUpdateShippingMethodsUrl()) ?>",
                "isAjax": <?= /* @noEscape */ $block->getUseAjax() ? 'true' : 'false' ?>,
                "canEditShippingMethod": <?= /* @noEscape */ $block->canEditShippingMethod() ? 'true' : 'false' ?>
            }
        }
    }
</script>
